# Lecture Search Engine — environment overrides.
# Copy this to .env and fill in real values. python-dotenv loads .env
# automatically when the package starts.

# ============================================================================
# LLM provider — Lightning AI (or any OpenAI-compatible endpoint)
# ============================================================================
# Required. The OpenAI-compatible chat-completions root URL.
LECTURE_SEARCH_LLM_BASE_URL=https://lightning.ai/api/v1/

# Required. Your provider API key.
LECTURE_SEARCH_LLM_API_KEY=your-api-key-here

# The model name as exposed by the provider.
LECTURE_SEARCH_LLM_MODEL=lightning-ai/deepseek-v4-pro

# ---- Optional: generation params -------------------------------------------
# LECTURE_SEARCH_LLM_TEMPERATURE=0.2
# LECTURE_SEARCH_LLM_TOP_P=0.9
# LECTURE_SEARCH_LLM_MAX_TOKENS=1024
# LECTURE_SEARCH_LLM_TIMEOUT=120

# ============================================================================
# Paths (default: <repo>/data, <repo>/logs)
# ============================================================================
# LECTURE_SEARCH_DATA_DIR=/var/lib/lecture-search
# LECTURE_SEARCH_VIDEOS_DIR=/var/lib/lecture-search/videos
# LECTURE_SEARCH_CHROMA_DIR=/var/lib/lecture-search/chroma
# LECTURE_SEARCH_SQLITE_PATH=/var/lib/lecture-search/lectures.db
# LECTURE_SEARCH_TEMP_DIR=/tmp/lecture-search

# ============================================================================
# Local models
# ============================================================================
# all-MiniLM-L6-v2 (384d, fast) | all-mpnet-base-v2 (768d, default) | multi-qa-mpnet-base-dot-v1
# LECTURE_SEARCH_EMBEDDING_MODEL=all-mpnet-base-v2
# tiny | base | small | medium | large | large-v2
# LECTURE_SEARCH_WHISPER_MODEL=medium
#
# On Hugging Face Spaces *free* (CPU-only) tier, Whisper-medium works but
# is slow (~15-25 min for a 30-min video). Drop to base/small if you want
# faster transcription at lower quality.

# ---- Devices (auto-detected if unset) --------------------------------------
# LECTURE_SEARCH_EMBEDDING_DEVICE=cuda
# LECTURE_SEARCH_WHISPER_DEVICE=cuda

# ============================================================================
# Processing
# ============================================================================
# LECTURE_SEARCH_CHUNK_DURATION=45
# LECTURE_SEARCH_CHUNK_OVERLAP=10
# LECTURE_SEARCH_DEFAULT_TOP_K=5
# LECTURE_SEARCH_MAX_TOP_K=30

# ============================================================================
# API & UI
# ============================================================================
# LECTURE_SEARCH_API_HOST=0.0.0.0
# LECTURE_SEARCH_API_PORT=8000
# LECTURE_SEARCH_MAX_UPLOAD_BYTES=1048576000
# LECTURE_SEARCH_API_BASE_URL=http://localhost:8000
